// Prisma Schema for CELPIP Auth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  referralSource  String?
  showInRanking   Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  verificationTokens VerificationToken[]
  passwordResets  PasswordReset[]
  practices       Practice[]
  writingAnalyses WritingAnalysis[]
  activityLogs    ActivityLog[]
  dailyUsages     DailyUsage[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// User practice history (for syncing progress)
model Practice {
  id          String   @id @default(cuid())
  userId      String
  taskType    String   // 'task1' or 'task2'
  wordCount   Int
  score       Float
  timeMinutes Int
  content     String?  @db.Text
  feedback    Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("practices")
}

// AI Writing Analysis (for weakness tracking & progress)
model WritingAnalysis {
  id            String   @id @default(cuid())
  oderId        String   @unique @default(cuid()) // for localStorage sync
  sessionId     String?  // anonymous session tracking
  userId        String?  // if logged in
  taskType      String   // 'task1' or 'task2'
  wordCount     Int
  aiScore       Int      // 1-12
  content       String   @db.Text
  
  // Weakness categories (count of issues)
  grammarIssues     Int @default(0)
  vocabularyIssues  Int @default(0)
  structureIssues   Int @default(0)
  contentIssues     Int @default(0)
  styleIssues       Int @default(0)
  
  // Specific patterns detected
  hasContractions   Boolean @default(false)
  hasOrgWords       Boolean @default(true)
  hasSpecificDetails Boolean @default(false)
  hasProperClosing  Boolean @default(false)
  
  // Raw AI feedback for reference
  sentenceFeedback  Json?
  scoreFeedback     Json?
  
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@map("writing_analyses")
}

// User subscription plan (keyed by Supabase auth user ID)
model UserPlan {
  id                    String   @id @default(cuid())
  userId                String   @unique  // Supabase auth user.id
  plan                  String   @default("free") // 'free' | 'pro'
  expiresAt             DateTime? // null = never expires (lifetime or free)
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("user_plans")
}

// Quiz score tracking (for technique guide quizzes)
model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  sectionId String   // 'listening', 'writing', 'reading', 'speaking'
  moduleId  String   // e.g. 'task1', 'csf', 'truthTrio'
  score     Int
  total     Int
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, sectionId, moduleId])
  @@map("quiz_attempts")
}

// Onboarding data (synced across devices)
model UserOnboarding {
  id        String   @id @default(cuid())
  userId    String   @unique  // Supabase auth user.id
  completed Boolean  @default(false)
  targetCLB Int?
  goal      String?  // 'immigration' | 'work' | 'study' | 'improvement'
  experience String? // 'first-time' | 'took-once' | 'multiple-times' | 'preparing'
  timeline  String?  // '1-month' | '2-3-months' | '3-6-months' | 'flexible'
  assessmentScores Json? // { reading: number, listening: number, writing: number, speaking: number }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_onboarding")
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String   @default("popup") // popup, footer, blog
  createdAt DateTime @default(now())

  @@map("email_subscribers")
}

model ApiUsage {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  date      String   // YYYY-MM-DD
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, endpoint, date])
  @@map("api_usage")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "reading" | "listening" | "writing" | "speaking"
  points    Int      // 1 or 2
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("activity_logs")
}

model DailyUsage {
  id        String   @id @default(cuid())
  userId    String
  date      String   // "YYYY-MM-DD"
  count     Int      @default(0)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("daily_usage")
}

// ══════════════════════════════════════════
// English Learning Module
// ══════════════════════════════════════════

model EnglishLevel {
  id           Int             @id @default(autoincrement())
  number       Int             @unique
  name         String
  theme        String
  cefr         String
  clb          String
  certName     String
  totalLessons Int
  isFree       Boolean         @default(false)
  lessons      EnglishLesson[]

  @@map("english_levels")
}

model EnglishLesson {
  id           Int                 @id @default(autoincrement())
  levelId      Int
  level        EnglishLevel        @relation(fields: [levelId], references: [id])
  number       Int
  title        String
  situation    String
  grammarFocus String
  keyPhrases   String[]
  imageUrl     String?
  dialogue     Json
  vocabulary   Json
  exercises    EnglishExercise[]
  completions  LessonCompletion[]

  @@unique([levelId, number])
  @@map("english_lessons")
}

model EnglishExercise {
  id       Int           @id @default(autoincrement())
  lessonId Int
  lesson   EnglishLesson @relation(fields: [lessonId], references: [id])
  type     String
  order    Int
  question Json
  options  Json?
  correct  Json
  hint     String?
  points   Int           @default(10)

  @@map("english_exercises")
}

model LessonCompletion {
  id          Int           @id @default(autoincrement())
  userId      String
  lessonId    Int
  lesson      EnglishLesson @relation(fields: [lessonId], references: [id])
  score       Int
  xpEarned    Int
  timeSeconds Int
  completedAt DateTime      @default(now())

  @@unique([userId, lessonId])
  @@map("lesson_completions")
}

model UserEnglishProgress {
  id               Int       @id @default(autoincrement())
  userId           String    @unique
  currentLevel     Int       @default(1)
  currentLesson    Int       @default(1)
  totalXp          Int       @default(0)
  streakDays       Int       @default(0)
  lastPracticeAt   DateTime?
  wordsLearned     Int       @default(0)
  lessonsCompleted Int       @default(0)
  certificates     Json      @default("[]")

  @@map("user_english_progress")
}

model UserVocabulary {
  id          Int      @id @default(autoincrement())
  userId      String
  word        String
  translation String
  imageUrl    String?
  strength    Int      @default(1)
  nextReview  DateTime @default(now())
  reviewCount Int      @default(0)

  @@unique([userId, word])
  @@map("user_vocabulary")
}

model SkillScore {
  id        String   @id @default(cuid())
  userId    String
  skill     String   // reading, listening, writing, speaking
  score     Float    // CELPIP scale 0-12
  correct   Int      @default(0)
  total     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("skill_scores")
  @@index([userId, skill])
}
