generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String              @unique
  emailVerified      DateTime?
  password           String?
  image              String?
  referralSource     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  showInRanking      Boolean             @default(true)
  referral_code      String?             @unique
  accounts           Account[]
  activityLogs       ActivityLog[]
  dailyUsages        DailyUsage[]
  email_sequence     email_sequence?
  passwordResets     PasswordReset[]
  practices          Practice[]
  referrals          referrals[]
  sessions           Session[]
  userFeedback       UserFeedback[]
  verificationTokens VerificationToken[]
  writingAnalyses    WritingAnalysis[]

  @@index([referral_code], map: "idx_users_referral_code")
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model Practice {
  id          String   @id @default(cuid())
  userId      String
  taskType    String
  wordCount   Int
  score       Float
  timeMinutes Int
  content     String?
  feedback    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("practices")
}

model WritingAnalysis {
  id                 String   @id @default(cuid())
  oderId             String   @unique @default(cuid())
  sessionId          String?
  userId             String?
  taskType           String
  wordCount          Int
  aiScore            Int
  content            String
  grammarIssues      Int      @default(0)
  vocabularyIssues   Int      @default(0)
  structureIssues    Int      @default(0)
  contentIssues      Int      @default(0)
  styleIssues        Int      @default(0)
  hasContractions    Boolean  @default(false)
  hasOrgWords        Boolean  @default(true)
  hasSpecificDetails Boolean  @default(false)
  hasProperClosing   Boolean  @default(false)
  sentenceFeedback   Json?
  scoreFeedback      Json?
  createdAt          DateTime @default(now())
  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@map("writing_analyses")
}

model UserPlan {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String    @default("free")
  expiresAt            DateTime?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("user_plans")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  sectionId String
  moduleId  String
  score     Int
  total     Int
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, sectionId, moduleId])
  @@map("quiz_attempts")
}

model UserOnboarding {
  id               String   @id @default(cuid())
  userId           String   @unique
  completed        Boolean  @default(false)
  targetCLB        Int?
  goal             String?
  experience       String?
  timeline         String?
  assessmentScores Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  dailyMinutes     String?
  focusSkills      String?
  source           String?
  canadaStatus     String?

  @@map("user_onboarding")
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String   @default("popup")
  createdAt DateTime @default(now())

  @@map("email_subscribers")
}

model ApiUsage {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  date      String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, endpoint, date])
  @@map("api_usage")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  points    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("activity_logs")
}

model DailyUsage {
  id       String @id @default(cuid())
  userId   String
  date     String
  count    Int    @default(0)
  category String @default("practice")
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, date, category])
  @@map("daily_usage")
}

model EnglishLevel {
  id           Int             @id @default(autoincrement())
  number       Int             @unique
  name         String
  theme        String
  cefr         String
  clb          String
  certName     String
  totalLessons Int
  isFree       Boolean         @default(false)
  lessons      EnglishLesson[]

  @@map("english_levels")
}

model EnglishLesson {
  id           Int                @id @default(autoincrement())
  levelId      Int
  number       Int
  title        String
  situation    String
  grammarFocus String
  keyPhrases   String[]
  imageUrl     String?
  dialogue     Json
  vocabulary   Json
  exercises    EnglishExercise[]
  level        EnglishLevel       @relation(fields: [levelId], references: [id])
  completions  LessonCompletion[]

  @@unique([levelId, number])
  @@map("english_lessons")
}

model EnglishExercise {
  id       Int           @id @default(autoincrement())
  lessonId Int
  type     String
  order    Int
  question Json
  options  Json?
  correct  Json
  hint     String?
  points   Int           @default(10)
  lesson   EnglishLesson @relation(fields: [lessonId], references: [id])

  @@map("english_exercises")
}

model LessonCompletion {
  id          Int           @id @default(autoincrement())
  userId      String
  lessonId    Int
  score       Int
  xpEarned    Int
  timeSeconds Int
  completedAt DateTime      @default(now())
  lesson      EnglishLesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("lesson_completions")
}

model UserEnglishProgress {
  id               Int       @id @default(autoincrement())
  userId           String    @unique
  currentLevel     Int       @default(1)
  currentLesson    Int       @default(1)
  totalXp          Int       @default(0)
  streakDays       Int       @default(0)
  lastPracticeAt   DateTime?
  wordsLearned     Int       @default(0)
  lessonsCompleted Int       @default(0)
  certificates     Json      @default("[]")

  @@map("user_english_progress")
}

model UserVocabulary {
  id          Int      @id @default(autoincrement())
  userId      String
  word        String
  translation String
  imageUrl    String?
  strength    Int      @default(1)
  nextReview  DateTime @default(now())
  reviewCount Int      @default(0)

  @@unique([userId, word])
  @@map("user_vocabulary")
}

model SkillScore {
  id        String   @id @default(cuid())
  userId    String
  skill     String
  score     Float
  correct   Int      @default(0)
  total     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, skill])
  @@map("skill_scores")
}

model UserFeedback {
  id         String   @id @default(uuid())
  userId     String
  challenge  String?
  suggestion String?
  createdAt  DateTime @default(now())
  rating     Int?
  category   String?  @default("general")
  page       String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_feedback")
}

model StreakData {
  id              String    @id @default(cuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastPracticeAt  DateTime?
  freezesUsed     Int       @default(0)
  freezeLastReset DateTime  @default(now())
  streakFrozenAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("streak_data")
}

model Notification {
  id        String             @id @default(cuid())
  title     String
  message   String
  type      String             @default("info")
  link      String?
  createdAt DateTime           @default(now())
  reads     NotificationRead[]

  @@map("notifications")
}

model NotificationRead {
  id             String       @id @default(cuid())
  userId         String
  notificationId String
  readAt         DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@map("notification_reads")
}

model battle_rooms {
  id               Int             @id @default(autoincrement())
  code             String          @unique @db.VarChar(8)
  mode             String          @default("quick") @db.VarChar(10)
  status           String          @default("waiting") @db.VarChar(12)
  player1_id       String
  player2_id       String?
  questions        Json            @default("[]")
  current_round    Int             @default(0)
  round_started_at DateTime?       @db.Timestamptz(6)
  created_at       DateTime?       @default(now()) @db.Timestamptz(6)
  finished_at      DateTime?       @db.Timestamptz(6)
  battle_rounds    battle_rounds[]

  @@index([code], map: "idx_battle_rooms_code")
  @@index([status], map: "idx_battle_rooms_status")
}

model battle_rounds {
  id           Int          @id @default(autoincrement())
  room_id      Int
  question_idx Int
  player_id    String
  answer       Int?
  correct      Boolean      @default(false)
  accuracy     Float?
  time_ms      Int?
  created_at   DateTime?    @default(now()) @db.Timestamptz(6)
  battle_rooms battle_rooms @relation(fields: [room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([room_id], map: "idx_battle_rounds_room")
}

model battle_stats {
  id             Int       @id @default(autoincrement())
  user_id        String    @unique
  wins           Int       @default(0)
  losses         Int       @default(0)
  draws          Int       @default(0)
  rating         Int       @default(1000)
  battles_played Int       @default(0)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)

  @@index([rating(sort: Desc)], map: "idx_battle_stats_rating")
  @@index([user_id], map: "idx_battle_stats_user")
}

model drill_progress {
  id           Int       @id @default(autoincrement())
  user_id      String
  drill_type   String
  level_id     String
  score        Int?      @default(0)
  total        Int?      @default(0)
  completed    Boolean?  @default(false)
  completed_at DateTime? @db.Timestamptz(6)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([user_id, drill_type, level_id])
}

model email_preferences {
  id              Int       @id @default(autoincrement())
  user_id         String?
  email           String    @unique
  unsubscribed    Boolean?  @default(false)
  unsubscribed_at DateTime? @db.Timestamptz(6)
  token           String    @unique
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
}

model email_sequence {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId       String    @unique
  step         Int       @default(0)
  lastSentAt   DateTime? @db.Timestamptz(6)
  unsubscribed Boolean?  @default(false)
  createdAt    DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @db.Timestamptz(6)
  users        User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([step], map: "idx_email_seq_step")
  @@index([unsubscribed], map: "idx_email_seq_unsub")
}

model guest_usage {
  ip    String
  date  String
  count Int    @default(0)

  @@id([ip, date])
}

model push_tokens {
  id        Int       @id @default(autoincrement())
  userId    String
  token     String
  platform  String    @default("android")
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([userId, platform])
  @@index([userId], map: "idx_push_tokens_user")
}

model referrals {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  referrer_id    String
  referred_id    String?
  referred_email String?
  status         String    @default("pending")
  days_rewarded  Int       @default(0)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  paid_at        DateTime? @db.Timestamptz(6)
  users          User      @relation(fields: [referrer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_referrer")

  @@index([referred_id], map: "idx_referrals_referred")
  @@index([referrer_id], map: "idx_referrals_referrer")
}
